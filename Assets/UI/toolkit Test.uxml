<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/Testing%20style.uss?fileID=7433441132597879392&amp;guid=a9b826c2c438ed441864339ba88c6cfc&amp;type=3#Testing style" />
    <ui:VisualElement name="MainContainer" style="flex-grow: 1; background-image: none; background-color: rgb(72, 72, 72); flex-direction: column;">
        <ui:VisualElement name="Reference" enabled="true" style="flex-grow: 1; background-image: url(&quot;project://database/Assets/Imported%20Assets/2D/Triangle-Strategy10032022-121613-3576.jpg?fileID=2800000&amp;guid=8912b1015dd7c674390ad94e307fdef0&amp;type=3#Triangle-Strategy10032022-121613-3576&quot;); background-color: rgba(0, 0, 0, 0); -unity-background-image-tint-color: rgba(255, 255, 255, 0);">
            <ui:VisualElement name="CharacterSelection" style="flex-grow: 0.15; flex-direction: row; align-items: flex-start; align-content: center; justify-content: center; height: 13%;">
                <ui:VisualElement name="CharLeft" style="flex-grow: 1; align-items: center; width: auto; flex-direction: row; max-width: 7%; justify-content: flex-end; align-self: stretch;">
                    <ui:Button text="L" class="CharSelectButton" style="scale: 1.1 1.1;" />
                </ui:VisualElement>
                <ui:GroupBox style="align-items: center; align-self: stretch; flex-grow: 1; flex-shrink: 1; max-width: none; flex-direction: row; justify-content: center; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;">
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                    <ui:Button name="Portrait" class="Portrait" />
                </ui:GroupBox>
                <ui:VisualElement name="CharRight" style="flex-grow: 1; align-items: center; width: auto; flex-direction: row; max-width: 7%; align-self: stretch;">
                    <ui:Button text="R" class="CharSelectButton" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="InfoDisplay" style="flex-grow: 1; flex-direction: row;">
                <ui:VisualElement name="CharacterPanel" style="flex-grow: 1; max-width: 27.5%; flex-direction: column-reverse; align-items: flex-start; background-color: rgba(195, 195, 195, 0.48);">
                    <ui:GroupBox name="Display" style="justify-content: flex-start; align-self: flex-start; left: 10%; bottom: 12%; width: 85%;">
                        <ui:GroupBox name="LevelDisplay" style="flex-direction: row;">
                            <ui:Label text="Lv.50" name="Level" class="Level" />
                            <ui:Label text="Exp -" class="Exp" />
                        </ui:GroupBox>
                        <ui:Label text="Serenoa" class="CharacterName" />
                        <ui:Label text="Swordmaster" class="ClassName" />
                        <ui:Label text="HP 531 / 531" class="HealthNumber" />
                        <ui:VisualElement style="flex-grow: 1; height: 100%; max-height: 100%;">
                            <ui:Button text="Button" style="color: rgba(0, 0, 0, 0); height: auto; max-height: none; flex-grow: 1; flex-shrink: 1;" />
                        </ui:VisualElement>
                    </ui:GroupBox>
                </ui:VisualElement>
                <ui:VisualElement name="InfoPanel" style="flex-grow: 1;">
                    <ui:VisualElement name="Top" style="flex-grow: 1; max-width: 100%; max-height: 15%; height: auto; align-items: flex-end;">
                        <ui:Button name="CharacterSprite" style="flex-direction: row; flex-grow: 1; flex-shrink: 1; max-width: 20%; width: 9%; top: 0%; right: 5%; background-color: rgb(255, 255, 255); height: 80%; max-height: 80%;" />
                    </ui:VisualElement>
                    <ui:VisualElement name="Middle" style="flex-grow: 1; flex-direction: row; width: 100%; height: 30%;">
                        <ui:VisualElement name="LeftTable" style="flex-grow: 1; max-width: 51%;">
                            <ui:VisualElement name="Weapon" style="flex-grow: 1; max-height: 14%; top: 0%;">
                                <ui:Label text="Weapon" class="TableHeader" />
                                <ui:Label text="Sword of Libra" class="TableContent" />
                            </ui:VisualElement>
                            <ui:VisualElement name="Accessories" style="flex-grow: 1; max-height: 22%; top: 0%;">
                                <ui:Label text="Accessories" class="TableHeader" />
                                <ui:Label text="Strength Ring" class="TableContent" />
                                <ui:Label text="HP Ring" class="TableContent" />
                            </ui:VisualElement>
                            <ui:VisualElement name="Stats" style="flex-grow: 1; height: 50%; max-height: 60%;">
                                <ui:Label text="Stats" class="TableHeader" />
                                <ui:VisualElement name="Table" style="flex-grow: 1; flex-direction: row;">
                                    <ui:VisualElement name="Left" style="flex-grow: 1;">
                                        <ui:Label text="Strength" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Physical Defense" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Magic Attack" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Magic Defense" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Luck" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                    </ui:VisualElement>
                                    <ui:VisualElement name="Right" style="flex-grow: 1;">
                                        <ui:Label text="Accuracy" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Speed" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Evasion" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Jump" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                        <ui:Label text="Movement" class="TableContent">
                                            <ui:Label text="0" style="-unity-text-align: upper-right;" />
                                        </ui:Label>
                                    </ui:VisualElement>
                                </ui:VisualElement>
                            </ui:VisualElement>
                            <ui:VisualElement name="Resistances" style="flex-grow: 1; max-height: 16%; top: 2%;">
                                <ui:Label text="Resistances" class="TableHeader" />
                                <ui:VisualElement name="Stats" style="flex-grow: 1; background-color: rgba(0, 0, 0, 0.7); flex-direction: row; justify-content: center; align-items: center;">
                                    <ui:Label text="0%" class="Resistance" />
                                    <ui:Label text="0%" class="Resistance" style="font-size: 22px; color: rgb(255, 255, 255); -unity-text-align: upper-center; width: 25%;" />
                                    <ui:Label text="0%" class="Resistance" style="font-size: 22px; color: rgb(255, 255, 255); -unity-text-align: upper-center; width: 25%;" />
                                    <ui:Label text="0%" class="Resistance" style="font-size: 22px; color: rgb(255, 255, 255); -unity-text-align: upper-center; width: 25%;" />
                                </ui:VisualElement>
                            </ui:VisualElement>
                        </ui:VisualElement>
                        <ui:VisualElement name="RightTable" style="flex-grow: 1; width: auto; max-width: 45%; left: 0.5%;">
                            <ui:VisualElement name="Abilities" style="flex-grow: 1;">
                                <ui:Label text="Abilities" class="TableHeader" />
                                <ui:Label text="Delaying Strike" class="TableContent" />
                                <ui:Label text="Pursuit Stance" class="TableContent" />
                                <ui:Label text="Hawk Dive" class="TableContent" />
                                <ui:Label text="Counter Stance" class="TableContent" />
                                <ui:Label text="Sweeping Slash" class="TableContent" />
                                <ui:Label text="Strength in Numbers" class="TableContent" />
                                <ui:Label text="Shielding Stance" class="TableContent" />
                            </ui:VisualElement>
                            <ui:VisualElement name="WeaponSkill" style="flex-grow: 1; max-height: 35%; height: 30%;">
                                <ui:Label text="Weapon Skill" class="TableHeader" />
                                <ui:Label text="Under Conviction&apos;s Banner" class="TableContent" />
                            </ui:VisualElement>
                        </ui:VisualElement>
                    </ui:VisualElement>
                    <ui:VisualElement name="Bottom" style="flex-grow: 1; height: auto; max-height: 12%; flex-direction: row; justify-content: flex-end; align-self: auto;">
                        <ui:Button class="ExitButton" />
                    </ui:VisualElement>
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
